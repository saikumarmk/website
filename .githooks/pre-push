#!/bin/sh
# Block push when mirrored assets or the production build would fail.
# Skip in a pinch: SKIP_PRE_PUSH=1 git push
set -e

if [ -n "$SKIP_PRE_PUSH" ]; then
  echo "pre-push: skipped (SKIP_PRE_PUSH is set)"
  exit 0
fi

root="$(git rev-parse --show-toplevel)"
cd "$root"

echo "pre-push: verifying urara asset mirrors..."
pnpm run verify:assets

echo "pre-push: running production build (this may take a minute)..."
pnpm run build

echo "pre-push: verifying build output contains mirrored assets..."
pnpm run verify:assets -- --build

echo "pre-push: ok"
